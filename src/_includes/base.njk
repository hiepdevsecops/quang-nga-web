<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{% if seo.metaTitle %}{{ seo.metaTitle }}{% elif title %}{{ title }} — {{ site.brand }}{% else %}{{ site.name }}{% endif %}</title>
<meta name="description" content="{{ seo.metaDescription or description or excerpt or 'Trung tâm bảo hành, sửa chữa thiết bị nhà bếp Quang Nga: bếp từ, bếp hồng ngoại, lò vi sóng, lò nướng, máy hút mùi, máy rửa bát. Thợ đến tận nhà, bảo hành dài hạn.' }}">
{% if seo.keywords %}<meta name="keywords" content="{{ seo.keywords | join(', ') }}">{% endif %}
<link rel="canonical" href="{{ site.url }}{{ page.url }}">
<meta property="og:type" content="website">
<meta property="og:title" content="{% if seo.metaTitle %}{{ seo.metaTitle }}{% elif title %}{{ title }}{% else %}{{ site.name }}{% endif %}">
<meta property="og:description" content="{{ seo.metaDescription or description or excerpt or 'Sửa chữa - bảo hành thiết bị nhà bếp tận nhà.' }}">
<meta property="og:url" content="{{ site.url }}{{ page.url }}">
<link rel="stylesheet" href="/css/style.css">
<script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": {{ site.name | dump | safe }},
  "image": {{ (site.url + "/uploads/cover-thiet-bi.svg") | dump | safe }},
  "url": {{ site.url | dump | safe }},
  "telephone": {{ (lienhe.phone1 | telLink) | dump | safe }},
  "description": "Trung tâm bảo hành, sửa chữa thiết bị nhà bếp: bếp từ, bếp điện, điều hòa, máy giặt, máy rửa bát, lò vi sóng. Thợ tận nhà, bảo hành dài hạn.",
  "areaServed": {{ lienhe.area | dump | safe }},
  "openingHours": "Mo-Su 08:00-20:00"
}
</script>
</head>
<body>

<header>
  <div class="wrap top-bar">
    <a href="/" class="logo">TRUNG TÂM BẢO HÀNH<br>SỬA CHỮA NHÀ BẾP <span>{{ site.brand }}</span></a>
    <nav class="menu">
      <a href="/">Trang chủ</a>
      <a href="/#dichvu">Dịch vụ</a>
      <a href="/#quytrinh">Quy trình</a>
      <a href="/blog/">Bài viết</a>
      <a href="/#lienhe">Liên hệ</a>
    </nav>
    <a href="tel:{{ lienhe.phone1 | telLink }}" class="hotline-top">☎ {{ lienhe.phone1 }}</a>
    <button class="hamburger" aria-label="Mở menu">☰</button>
  </div>
</header>

{{ content | safe }}

<footer>
  © 2026 {{ site.name }}.<br>
  ☎ Hotline: {{ lienhe.phone1 }}{% if lienhe.phone2 %} – {{ lienhe.phone2 }}{% endif %} &nbsp;·&nbsp; Hỗ trợ Zalo / Facebook 24/7
</footer>

<div class="float">
  <a href="tel:{{ lienhe.phone1 | telLink }}" class="f-goi">GỌI</a>
  <a href="https://zalo.me/{{ lienhe.zalo | telLink }}" class="f-zalo">ZALO</a>
</div>

<script src="/js/main.js"></script>
<script>
  // Khi nhận lời mời / xác nhận, tự chuyển vào trang quản trị sau khi đăng nhập
  if (window.netlifyIdentity) {
    window.netlifyIdentity.on("init", function (user) {
      if (!user) {
        window.netlifyIdentity.on("login", function () {
          document.location.href = "/admin/";
        });
      }
    });
  }
</script>
</body>
</html>
